generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ActivityLog {
  id        String   @id @default(cuid())
  level     String   @default("info")
  category  String
  message   String
  details   String?
  createdAt DateTime @default(now())

  @@index([category])
  @@index([level])
  @@index([createdAt(sort: Desc)])
}

model BotConfig {
  id                     String       @id @default(cuid())
  name                   String       @default("Sniper Bot")
  isActive               Boolean      @default(false)
  exchange               String       @default("uniswap")
  network                String       @default("ethereum")
  rpcUrl                 String?
  targetToken            String?
  targetTokenSymbol      String?
  targetTokenName        String?
  baseToken              String       @default("WETH")
  strategy               String       @default("momentum")
  strategyParams         String?
  buyTriggerType         String       @default("price_drop")
  buyTriggerValue        Float        @default(0.0)
  buyAmount              Float        @default(0.1)
  buySlippage            Float        @default(5.0)
  buyGasPrice            Float        @default(50.0)
  buyGasLimit            Int          @default(500000)
  minLiquidity           Float        @default(100.0)
  maxBuyPrice            Float?
  sellTriggerType        String       @default("take_profit")
  sellTriggerValue       Float        @default(0.0)
  sellSlippage           Float        @default(5.0)
  sellGasPrice           Float        @default(50.0)
  sellGasLimit           Int          @default(500000)
  takeProfitEnabled      Boolean      @default(true)
  takeProfitPercent      Float        @default(50.0)
  takeProfitAmount       Float        @default(100.0)
  stopLossEnabled        Boolean      @default(true)
  stopLossPercent        Float        @default(15.0)
  stopLossType           String       @default("fixed")
  trailingStopEnabled    Boolean      @default(false)
  trailingStopPercent    Float        @default(10.0)
  trailingStopActivation Float        @default(20.0)
  positionSizingType     String       @default("fixed")
  positionSizeValue      Float        @default(0.1)
  maxPositionSize        Float        @default(1.0)
  minPositionSize        Float        @default(0.01)
  maxDailyLoss           Float        @default(0.5)
  maxDailyTrades         Int          @default(10)
  maxOpenPositions       Int          @default(5)
  cooldownPeriod         Int          @default(300)
  autoApprove            Boolean      @default(false)
  mevProtection          Boolean      @default(true)
  flashLoanDetection     Boolean      @default(true)
  autoSweepEnabled       Boolean      @default(false)
  sweepChains            String       @default("")
  sweepInterval          Int          @default(30)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  Position               Position[]
  PriceAlert             PriceAlert[]
  Trade                  Trade[]
}

model MarketData {
  id             String   @id @default(cuid())
  tokenAddress   String   @unique
  symbol         String?
  name           String?
  decimals       Int?
  price          Float?
  priceChange24h Float?
  volume24h      Float?
  marketCap      Float?
  liquidity      Float?
  lastUpdated    DateTime @default(now())

  @@index([symbol])
}

model Position {
  id                String    @id @default(cuid())
  botConfigId       String
  tokenAddress      String
  tokenSymbol       String?
  tokenName         String?
  entryPrice        Float
  entryPriceUsd     Float?
  amount            Float
  valueIn           Float
  currentValue      Float?
  highestPrice      Float?
  lowestPrice       Float?
  stopLossPrice     Float?
  takeProfitPrice   Float?
  trailingStopPrice Float?
  status            String    @default("open")
  openedAt          DateTime  @default(now())
  closedAt          DateTime?
  updatedAt         DateTime  @updatedAt
  BotConfig         BotConfig @relation(fields: [botConfigId], references: [id])
  Trade             Trade[]

  @@index([botConfigId])
  @@index([openedAt(sort: Desc)])
  @@index([status])
}

model PriceAlert {
  id           String    @id @default(cuid())
  botConfigId  String
  tokenAddress String
  tokenSymbol  String?
  alertType    String
  targetValue  Float
  currentValue Float?
  triggered    Boolean   @default(false)
  triggeredAt  DateTime?
  action       String
  actionParams String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  BotConfig    BotConfig @relation(fields: [botConfigId], references: [id])

  @@index([botConfigId])
  @@index([triggered])
}

model Trade {
  id                String    @id @default(cuid())
  botConfigId       String
  positionId        String?
  type              String
  status            String    @default("pending")
  tokenAddress      String
  tokenSymbol       String?
  tokenName         String?
  amountIn          Float
  amountOut         Float
  price             Float
  priceUsd          Float?
  txHash            String?   @unique
  blockNumber       Int?
  gasUsed           Float?
  gasPrice          Float?
  gasCost           Float?
  triggerType       String?
  triggerValue      Float?
  slippageActual    Float?
  profitLoss        Float?
  profitLossPercent Float?
  profitLossUsd     Float?
  executedAt        DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  errorMessage      String?
  Position          Position? @relation(fields: [positionId], references: [id])
  BotConfig         BotConfig @relation(fields: [botConfigId], references: [id])

  @@index([type])
  @@index([botConfigId])
  @@index([createdAt(sort: Desc)])
  @@index([status])
}
